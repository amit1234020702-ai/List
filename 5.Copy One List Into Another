import java.util.*;

public class Main {
    public static void main(String[] args) {

        ArrayList<Integer> list1 = new ArrayList<>();

        list1.add(10);
        list1.add(20);
        list1.add(30);
        list1.add(40);
        list1.add(50);

        ArrayList<Integer> list2 = new ArrayList<>();

        list2.addAll(list1);

        System.out.println("Original List : " + list1);
        System.out.println("Copied List   : " + list2);
    }
}
